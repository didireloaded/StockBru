generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String          @id @default(uuid())
  fullName       String
  email          String          @unique
  phone          String?
  role           String          // Admin, Manager, Bartender, Owner
  passwordHash   String
  createdAt      DateTime        @default(now())
  StockReceipts  StockReceipt[]
  StockMovements StockMovement[]
  StockTakes     StockTake[]
}

model Product {
  id                String              @id @default(uuid())
  name              String
  barcode           String?             @unique
  category          String
  unitType          String              // Bottle, Can, Unit
  bottleSizeMl      Int?
  shotSizeMl        Int?
  costPrice         Float
  sellingPrice      Float
  minimumStock      Int
  active            Boolean             @default(true)
  Inventory         Inventory?
  StockReceiptItems StockReceiptItem[]
  StockMovements    StockMovement[]
  StockTakeItems    StockTakeItem[]
}

model Inventory {
  id           String   @id @default(uuid())
  productId    String   @unique
  fullBottles  Int      @default(0)
  openBottleMl Int      @default(0)
  totalUnits   Int      @default(0) // For non-liquid
  updatedAt    DateTime @updatedAt
  Product      Product  @relation(fields: [productId], references: [id])
}

model StockReceipt {
  id            String             @id @default(uuid())
  supplier      String
  invoiceNumber String?
  receivedById  String
  dateReceived  DateTime           @default(now())
  User          User               @relation(fields: [receivedById], references: [id])
  Items         StockReceiptItem[]
}

model StockReceiptItem {
  id           String       @id @default(uuid())
  receiptId    String
  productId    String
  quantity     Int
  StockReceipt StockReceipt @relation(fields: [receiptId], references: [id])
  Product      Product      @relation(fields: [productId], references: [id])
}

model StockTake {
  id            String          @id @default(uuid())
  createdById   String
  dateStarted   DateTime        @default(now())
  dateCompleted DateTime?
  status        String          // Open, Completed
  User          User            @relation(fields: [createdById], references: [id])
  Items         StockTakeItem[]
}

model StockTakeItem {
  id               String    @id @default(uuid())
  stockTakeId      String
  productId        String
  expectedQuantity Int
  actualQuantity   Int
  variance         Int
  StockTake        StockTake @relation(fields: [stockTakeId], references: [id])
  Product          Product   @relation(fields: [productId], references: [id])
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  userId    String
  action    String   // STOCK_RECEIVED, BOTTLE_SOLD, SHOT_SOLD, ADJUSTMENT
  quantity  Float    // Can be negative
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id])
  User      User     @relation(fields: [userId], references: [id])
}
